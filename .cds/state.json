{
  "routingRules": [],
  "buildProfiles": [
    {
      "id": "api",
      "name": "api",
      "dockerImage": "mcr.microsoft.com/dotnet/sdk:8.0",
      "workDir": "prd-api",
      "containerWorkDir": "/app",
      "command": "dotnet restore && dotnet build --no-restore && dotnet run --project src/PrdAgent.Api --urls http://0.0.0.0:5000",
      "containerPort": 5000,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "MongoDB__ConnectionString": "mongodb://${CDS_HOST}:${CDS_MONGODB_PORT}",
        "MongoDB__DatabaseName": "prdagent",
        "Redis__ConnectionString": "${CDS_HOST}:${CDS_REDIS_PORT}",
        "Jwt__Secret": "TODO: 请填写实际值",
        "Jwt__Issuer": "prdagent",
        "ASSETS_PROVIDER": "tencentCos",
        "TENCENT_COS_BUCKET": "TODO: 请填写实际值",
        "TENCENT_COS_REGION": "TODO: 请填写实际值",
        "TENCENT_COS_SECRET_ID": "TODO: 请填写实际值",
        "TENCENT_COS_SECRET_KEY": "TODO: 请填写实际值",
        "TENCENT_COS_PUBLIC_BASE_URL": "TODO: 请填写实际值",
        "TENCENT_COS_PREFIX": "data"
      },
      "pathPrefixes": [
        "/api/"
      ],
      "dependsOn": [
        "mongodb",
        "redis"
      ]
    },
    {
      "id": "admin",
      "name": "admin",
      "dockerImage": "node:20-slim",
      "workDir": "prd-admin",
      "containerWorkDir": "/app",
      "command": "corepack enable && pnpm install --frozen-lockfile && pnpm exec vite --host 0.0.0.0 --port 8000",
      "containerPort": 8000,
      "env": {},
      "pathPrefixes": [
        "/"
      ]
    }
  ],
  "branches": {},
  "nextPortIndex": 8,
  "logs": {},
  "defaultBranch": null,
  "customEnv": {},
  "infraServices": [
    {
      "id": "mongodb",
      "name": "MongoDB 8",
      "dockerImage": "mongo:8.0",
      "containerPort": 27017,
      "hostPort": 10001,
      "containerName": "cds-infra-mongodb",
      "status": "running",
      "volumes": [
        {
          "name": "mongodb-data",
          "containerPath": "/data/db",
          "type": "volume"
        }
      ],
      "env": {},
      "healthCheck": {
        "command": "mongosh --eval \"db.runCommand({ping:1})\" --quiet",
        "interval": 10,
        "retries": 3
      },
      "createdAt": "2026-03-15T13:03:50.669Z"
    },
    {
      "id": "redis",
      "name": "Redis 7",
      "dockerImage": "redis:7-alpine",
      "containerPort": 6379,
      "hostPort": 10002,
      "containerName": "cds-infra-redis",
      "status": "running",
      "volumes": [
        {
          "name": "redis-data",
          "containerPath": "/data",
          "type": "volume"
        }
      ],
      "env": {},
      "healthCheck": {
        "command": "redis-cli ping",
        "interval": 10,
        "retries": 3
      },
      "createdAt": "2026-03-15T13:03:50.669Z"
    }
  ],
  "mirrorEnabled": false
}