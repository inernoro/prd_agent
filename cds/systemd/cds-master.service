[Unit]
# CDS Master systemd unit (Phase 2 resilience)
#
# Installs CDS as a system service so that the kernel restarts it automatically
# after any crash (OOM, segfault, self-update failures). Pairs with the
# dist/index.js build artifact produced by `./exec_cds.sh` first run.
#
# Install:
#   sudo cp cds/systemd/cds-master.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now cds-master
#
# Inspect:
#   systemctl status cds-master
#   journalctl -u cds-master -f
#
# See doc/design.cds-resilience.md Phase 2.

Description=CDS Master (Cloud Development Suite)
Documentation=file:///home/user/prd_agent/doc/design.cds-resilience.md
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple

# IMPORTANT: edit these three paths to match your install location
WorkingDirectory=/opt/prd_agent/cds
Environment=NODE_ENV=production
Environment=CDS_REPO_ROOT=/opt/prd_agent
# Optionally pin the AI access key here (prefer /etc/cds/env for secrets)
EnvironmentFile=-/etc/cds/env

ExecStart=/usr/bin/node dist/index.js

# Restart policy — the whole point of this unit file
Restart=always
RestartSec=3s
# Prevent rapid restart loops: max 5 restarts in 60 seconds
StartLimitIntervalSec=60
StartLimitBurst=5

# Standard output goes to the journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cds-master

# Resource accounting (requires cgroup v2)
# Prevents the Master process from consuming more than it should
MemoryMax=512M
CPUQuota=100%

# Security hardening — soft, compatible with docker CLI usage
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/prd_agent /var/run/docker.sock
ProtectHome=false

[Install]
WantedBy=multi-user.target
