# ──────────────────────────────────────────────────────────────
# Host Nginx Main Config (generated by exec_setup.sh)
#
# This is the top-level nginx.conf mounted into the nginx container.
# CDS-specific server blocks are in cds-nginx.conf (included below).
#
# Mount mapping:
#   /path/to/nginx.conf      → /etc/nginx/nginx.conf
#   /path/to/cds-nginx.conf  → /etc/nginx/conf.d/cds.conf
#   /path/to/certs/           → /etc/nginx/certs
#   /path/to/www/             → /var/www/html
# ──────────────────────────────────────────────────────────────

worker_processes auto;

events {
    worker_connections 10240;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    client_max_body_size 200m;
    sendfile        on;
    tcp_nopush      on;
    tcp_nodelay     on;
    keepalive_timeout 65;

    access_log  /var/log/nginx/access.log;
    error_log   /var/log/nginx/error.log warn;

    # WebSocket upgrade map (used by all server blocks)
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    # Include all conf.d/*.conf (CDS conf goes here)
    include /etc/nginx/conf.d/*.conf;
}
