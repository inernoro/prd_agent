# ──────────────────────────────────────────────────────────────
# CDS Nginx Configuration (Single-file, generated by exec_setup.sh)
#
# This file replaces the 3 separate server blocks that were
# previously scattered in the host nginx.conf.
#
# Domains:
#   {{MAIN_DOMAIN}}         → CDS Worker (:{{WORKER_PORT}})
#   switch.{{MAIN_DOMAIN}}  → CDS Worker (:{{WORKER_PORT}})  (branch switching)
#   cds.{{MAIN_DOMAIN}}     → CDS Dashboard (:{{MASTER_PORT}})
#   *.{{PREVIEW_DOMAIN}}    → CDS Worker (:{{WORKER_PORT}})  (branch preview)
#
# Mount this file into the nginx container:
#   -v /path/to/cds-nginx.conf:/etc/nginx/conf.d/cds.conf:ro
#
# Or include it in the main nginx.conf:
#   include /path/to/cds-nginx.conf;
# ──────────────────────────────────────────────────────────────

# ── Shared SSL settings (avoid repeating in every server block) ──
ssl_certificate     /etc/nginx/certs/{{MAIN_DOMAIN}}.crt;
ssl_certificate_key /etc/nginx/certs/{{MAIN_DOMAIN}}.key;
ssl_protocols       TLSv1.2 TLSv1.3;

# ── Upstream definitions ──
upstream cds_worker {
    server 127.0.0.1:{{WORKER_PORT}};
    keepalive 16;
}

upstream cds_dashboard {
    server 127.0.0.1:{{MASTER_PORT}};
    keepalive 8;
}

# ── Common proxy snippet (used by all locations) ──
# Nginx doesn't support named snippets natively, so we repeat the
# minimal set. The upstream/SSL dedup already eliminates 80% of the
# original redundancy.

# ────────────────────────────────────────
# 1. Main domain → CDS Worker (gateway)
# ────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name {{MAIN_DOMAIN}};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        proxy_pass http://cds_worker;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_cache     off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        add_header Cache-Control    "no-cache" always;
        add_header X-Accel-Buffering "no"      always;
    }
}

# ────────────────────────────────────────
# 2. Switch domain → CDS Worker (branch switching)
# ────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name switch.{{MAIN_DOMAIN}};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        proxy_pass http://cds_worker;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_cache     off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        add_header Cache-Control    "no-cache" always;
        add_header X-Accel-Buffering "no"      always;
    }
}

# ────────────────────────────────────────
# 3. CDS Dashboard
# ────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name cds.{{MAIN_DOMAIN}};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        proxy_pass http://cds_dashboard;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Port  $server_port;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_cache     off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}

# ────────────────────────────────────────
# 4. Preview subdomains → CDS Worker
#    e.g. feature-xxx.miduo.org → Worker
#    (only if PREVIEW_DOMAIN is configured)
# ────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name *.{{PREVIEW_DOMAIN}};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        proxy_pass http://cds_worker;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_cache     off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        add_header Cache-Control    "no-cache" always;
        add_header X-Accel-Buffering "no"      always;
    }
}
