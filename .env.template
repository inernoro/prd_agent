# =============================================================
# PrdAgent Development Environment Variables
# Copy to .env and fill in actual values:  cp .env.template .env
# =============================================================

# --- Required ---

# MongoDB (password with special chars must be URL-encoded in connection string)
MONGODB_HOST=localhost
MONGODB_PASSWORD=
MongoDB__ConnectionString=mongodb://localhost:27017
MongoDB__DatabaseName=prdagent

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=
Redis__ConnectionString=localhost:6379

# JWT (must be >= 32 bytes)
Jwt__Secret=dev-only-change-me-32bytes-minimum!!

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# --- Optional: LLM ---

# LLM__ClaudeApiKey=sk-ant-xxx
# LLM__Model=claude-3-5-sonnet-20241022

# --- Optional: Object Storage (tencentCos / cloudflareR2) ---
# ASSETS_PROVIDER 决定使用哪个存储后端，两者二选一

# Option A: Tencent COS
# ASSETS_PROVIDER=tencentCos
# TENCENT_COS_BUCKET=
# TENCENT_COS_REGION=
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_PUBLIC_BASE_URL=
# TENCENT_COS_PREFIX=data

# Option B: Cloudflare R2
# ASSETS_PROVIDER=cloudflareR2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
# R2_PREFIX=
# R2_ENDPOINT=

# --- Optional: Root Admin ---

# ROOT_ACCESS_USERNAME=
# ROOT_ACCESS_PASSWORD=
